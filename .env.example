APP_NAME=events-service
APP_ENV=development
EVENTS_DATABASE_URL=sqlite:///data/events.db
# PostgreSQL example:
# EVENTS_DATABASE_URL=postgresql+psycopg://events:events@localhost:5432/events
SQLALCHEMY_ECHO=false

# Comma-separated browser origins allowed to call the API directly.
# Leave empty when a same-origin gateway or development proxy is used.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Active events are deleted this many days after their end time.
EVENT_DELETION_DELAY_DAYS=7

# Canceled events are deleted this many days after cancellation.
CANCELED_EVENT_DELETION_DELAY_DAYS=1

# Supported values: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO


